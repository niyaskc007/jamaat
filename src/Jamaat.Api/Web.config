<?xml version="1.0" encoding="utf-8"?>
<!--
  Source Web.config. `dotnet publish` for the ASP.NET Core SDK takes this file as the
  base, adds the <aspNetCore> handler block at publish time, and emits the merged
  copy into the publish output. So this file only needs to carry the bits the
  default generator leaves out.

  Why: the default Azure App Service IIS request filter caps request body size at
  30 MB. Our MaxMind upload endpoint accepts databases up to ~150 MB (a
  GeoLite2-City.mmdb is ~63 MB; tar.gz versions are smaller but still over 30 MB).
  Without the override here, the upload returns 413 "request entity too large"
  before it ever reaches the action where [RequestSizeLimit(150 MB)] would
  otherwise apply.
-->
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- 200 MB - generous headroom over the City .mmdb (63 MB) so an
             admin can upload the un-extracted .tar.gz too if they prefer. -->
        <requestLimits maxAllowedContentLength="209715200" />
      </requestFiltering>
    </security>
    <!-- IIS AspNetCore module's default startupTimeLimit is 120s and requestTimeout
         is 110s. Both are too tight: the seeder iterates every Member to provision
         a login (Identity password hashing + AspNet user create per row), and at
         150+ members it routinely takes 4-6 minutes on first run after a clean=true
         deploy. With the defaults, IIS kills the process at 120s while the seeder
         is still mid-loop, restarts it, kills it again, etc. - the "Managed server
         didn't initialize after 120000 ms" death loop seen in eventlog.xml. Bumping
         both to 10 minutes gives the seeder room without changing real runtime
         behaviour - once startup is done these limits don't apply. The element is
         hand-placed (not generated by dotnet publish) because publish strips the
         attributes if you let it generate the block from scratch. -->
    <aspNetCore processPath="dotnet" arguments=".\Jamaat.Api.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" startupTimeLimit="600" requestTimeout="00:10:00" />
  </system.webServer>
</configuration>
