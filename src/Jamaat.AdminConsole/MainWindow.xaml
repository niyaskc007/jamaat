<Window x:Class="Jamaat.AdminConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jamaat Admin Console"
        Height="720" Width="1080"
        MinHeight="540" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrandSurface}"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid>
        <!-- Title strip -->
        <Grid VerticalAlignment="Top" Background="{StaticResource BrandPrimary}" Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center" Grid.Column="0">
                <TextBlock Text="Jamaat" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="Admin Console" Foreground="#B7E0CC" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="lblConnection" Text="Not connected"
                       Foreground="#B7E0CC" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <Button x:Name="btnRefresh" Content="Refresh" Click="OnRefreshClick"
                        Background="Transparent" BorderBrush="#B7E0CC" BorderThickness="1" Foreground="White"
                        Margin="4,0" Visibility="Collapsed"/>
                <Button x:Name="btnDisconnect" Content="Disconnect" Click="OnDisconnectClick"
                        Background="Transparent" BorderBrush="#B7E0CC" BorderThickness="1" Foreground="White"
                        Margin="4,0" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <!-- Login panel -->
        <Border x:Name="loginPanel" Background="White" BorderBrush="{StaticResource BrandBorder}" BorderThickness="1"
                CornerRadius="8" Padding="32" Width="420"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Margin="0,48,0,0">
            <StackPanel>
                <TextBlock Text="Connect to a Jamaat install" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <TextBlock Text="API URL" Foreground="{StaticResource BrandMuted}" FontSize="11" Margin="0,4,0,4"/>
                <TextBox x:Name="tbApiUrl" Text="http://localhost:5174" Padding="8" FontSize="13"/>
                <TextBlock Text="Email" Foreground="{StaticResource BrandMuted}" FontSize="11" Margin="0,12,0,4"/>
                <TextBox x:Name="tbEmail" Padding="8" FontSize="13"/>
                <TextBlock Text="Password" Foreground="{StaticResource BrandMuted}" FontSize="11" Margin="0,12,0,4"/>
                <PasswordBox x:Name="pbPassword" Padding="8" FontSize="13"/>
                <TextBlock x:Name="lblLoginError" Foreground="{StaticResource StatusBad}" Margin="0,12,0,0"
                           TextWrapping="Wrap" Visibility="Collapsed"/>
                <Button x:Name="btnLogin" Content="Sign in" Click="OnLoginClick" Margin="0,16,0,0" Height="36"/>
                <TextBlock Foreground="{StaticResource BrandMuted}" FontSize="11" TextAlignment="Center" Margin="0,16,0,0">
                    Powered by Ubrixy Technologies
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Dashboard (visible after login) -->
        <Grid x:Name="dashboardPanel" Visibility="Collapsed" Margin="0,48,0,0">
            <TabControl Background="{StaticResource BrandSurface}" BorderThickness="0" Padding="0">
                <!-- Status tab -->
                <TabItem Header="Status">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <UniformGrid Columns="4" Rows="1">
                                <Border Style="{StaticResource KpiBorderStyle}">
                                    <StackPanel Margin="14">
                                        <TextBlock Text="Status" Foreground="{StaticResource BrandMuted}" FontSize="11"/>
                                        <TextBlock x:Name="kpiStatus" Text="-" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiBorderStyle}">
                                    <StackPanel Margin="14">
                                        <TextBlock Text="Users online" Foreground="{StaticResource BrandMuted}" FontSize="11"/>
                                        <TextBlock x:Name="kpiUsers" Text="-" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiBorderStyle}">
                                    <StackPanel Margin="14">
                                        <TextBlock Text="Requests / min" Foreground="{StaticResource BrandMuted}" FontSize="11"/>
                                        <TextBlock x:Name="kpiReqs" Text="-" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource KpiBorderStyle}">
                                    <StackPanel Margin="14">
                                        <TextBlock Text="Open alerts" Foreground="{StaticResource BrandMuted}" FontSize="11"/>
                                        <TextBlock x:Name="kpiAlerts" Text="-" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource KpiBorderStyle}" Margin="0,12,0,0">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Server" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <Grid x:Name="serverGrid">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource KpiBorderStyle}" Margin="0,12,0,0">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Database" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <Grid x:Name="dbGrid">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Operator actions: surfaced on the Status tab so the operator
                                 doesn't have to hunt for them. Both write to SystemAuditLog
                                 via the existing API endpoints. -->
                            <Border Style="{StaticResource KpiBorderStyle}" Margin="0,12,0,0">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Operator actions" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="btnForceGc" Content="Force GC" Click="OnForceGcClick"
                                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                        <Button x:Name="btnRestartSvc" Content="Restart service"
                                                Click="OnRestartServiceClick"
                                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="lblActionResult" VerticalAlignment="Center"
                                                   Foreground="{StaticResource BrandMuted}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tenants tab -->
                <TabItem Header="Tenants">
                    <DataGrid x:Name="dgTenants" Margin="16" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" BorderBrush="{StaticResource BrandBorder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding BaseCurrency}" Width="80"/>
                            <DataGridTextColumn Header="Members" Binding="{Binding MemberCount}" Width="90"/>
                            <DataGridTextColumn Header="Families" Binding="{Binding FamilyCount}" Width="90"/>
                            <DataGridTextColumn Header="Users" Binding="{Binding UserCount}" Width="80"/>
                            <DataGridTextColumn Header="Receipts" Binding="{Binding ReceiptCount}" Width="90"/>
                            <DataGridTextColumn Header="Last activity" Binding="{Binding LastActivityAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Logs tab - live tail of the most recent jamaat-*.log file. -->
                <TabItem Header="Logs">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Tail size:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="cbLogTake" Width="100" SelectedIndex="1">
                                <ComboBoxItem Content="100"/>
                                <ComboBoxItem Content="500"/>
                                <ComboBoxItem Content="1000"/>
                                <ComboBoxItem Content="5000"/>
                            </ComboBox>
                            <CheckBox x:Name="cbLogAutoRefresh" Content="Auto-refresh (8s)" IsChecked="True"
                                      VerticalAlignment="Center" Margin="16,0,0,0"/>
                            <Button Content="Refresh now" Click="OnRefreshLogsClick"
                                    Style="{StaticResource SecondaryButton}" Margin="16,0,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#0F172A" CornerRadius="4">
                            <ScrollViewer x:Name="logScroll" VerticalScrollBarVisibility="Auto"
                                          Padding="12">
                                <TextBox x:Name="tbLogTail" Background="Transparent" Foreground="#9FCDBF"
                                         BorderThickness="0" IsReadOnly="True" FontFamily="Consolas"
                                         FontSize="11" TextWrapping="NoWrap" AcceptsReturn="True"/>
                            </ScrollViewer>
                        </Border>
                        <TextBlock Grid.Row="2" x:Name="lblLogPath" Foreground="{StaticResource BrandMuted}"
                                   FontSize="11" Margin="0,8,0,0"/>
                    </Grid>
                </TabItem>

                <!-- Alerts tab -->
                <TabItem Header="Alerts">
                    <DataGrid x:Name="dgAlerts" Margin="16" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" BorderBrush="{StaticResource BrandBorder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                            <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="140"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="First seen" Binding="{Binding FirstSeenAtUtc, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeenAtUtc, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Repeats" Binding="{Binding RepeatCount}" Width="70"/>
                            <DataGridTextColumn Header="Acked" Binding="{Binding Acknowledged}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Errors tab -->
                <TabItem Header="Errors">
                    <DataGrid x:Name="dgErrors" Margin="16" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" BorderBrush="{StaticResource BrandBorder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When" Binding="{Binding OccurredAtUtc, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding HttpStatus}" Width="70"/>
                            <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="220"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Logins tab -->
                <TabItem Header="Logins">
                    <DataGrid x:Name="dgLogins" Margin="16" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" BorderBrush="{StaticResource BrandBorder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When" Binding="{Binding AttemptedAtUtc, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Result" Binding="{Binding Success}" Width="70"/>
                            <DataGridTextColumn Header="Identifier" Binding="{Binding Identifier}" Width="240"/>
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="140"/>
                            <DataGridTextColumn Header="Country" Binding="{Binding GeoCountry}" Width="100"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding FailureReason}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Audit tab -->
                <TabItem Header="Operator audit">
                    <DataGrid x:Name="dgAudit" Margin="16" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" BorderBrush="{StaticResource BrandBorder}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When" Binding="{Binding AtUtc, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding ActionKey}" Width="200"/>
                            <DataGridTextColumn Header="Operator" Binding="{Binding UserName}" Width="200"/>
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Brand footer -->
        <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,6"
                   Foreground="{StaticResource BrandMuted}" FontSize="11"
                   Text="© 2026 Jamaat · A product of Ubrixy Technologies (https://www.ubrixy.com/)"/>
    </Grid>
</Window>
