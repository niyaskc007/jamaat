# Installer artifacts (regenerated by installer/build.ps1)
installer/output/
installer/redist/
JamaatInstaller-*.exe

# Deploy artifacts (regenerated by `dotnet publish` + zipping for staging deploys)
publish/
deploy.zip

# Deployment secrets - this dir holds the SCM publish-profile and the production DB
# connection string. Both are surfaced by Azure portal / our DBA - they live next to
# the repo for local convenience but must never be committed.
docs/Deployments/

# Stray local-only docs dir often used for working files
docs/New folder/

# MaxMind GeoLite2 databases. ~63 MB each, distributed separately + uploaded via the
# admin/maxmind endpoint. Never check the binaries into git.
*.mmdb
src/Jamaat.Api/Maxmind/
